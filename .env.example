# Environment
NODE_ENV="production"

# Server
PORT=5050

# Database (Neon - Free Cloud PostgreSQL)
# Get this from: https://neon.tech/
# Format: postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/dbname?schema=public
DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/dbname?schema=public"

# Prisma Accelerate (optional)
ACCELERATE_URL=

# JWT
JWT_SECRET="2418d9f5be87b6aa9419e9b2c584e4eab5298a09fd4846a8e7dc2813be1759d7"
JWT_EXPIRES_IN="1h"

# Redis (QStash - Free Cloud Redis REST API)
# Get this from: https://upstash.com/
# Format: REST URL and Token (not Redis protocol)
UPSTASH_REDIS_REST_URL="https://your-redis-host.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token"
REDIS_HEALTH_CHECK_INTERVAL=30

# Sentry
SENTRY_DSN="https://947f0e2cf5eb1c43f5b652ee0cdfde04@o4509598466965504.ingest.us.sentry.io/4510544595910656"
